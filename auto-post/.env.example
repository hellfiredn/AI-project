WEBSITE_AUTHOR=your-wordpress-username
WEBSITE_APP_PASS=your-wordpress-application-password

# WordPress site + REST API
WEBSITE_URL=https://taphoagiamgia.com
WP_API_BASE=https://taphoagiamgia.com/wp-json/wp/v2
WP_POSTS_ENDPOINT=https://taphoagiamgia.com/wp-json/wp/v2/posts
WP_MEDIA_ENDPOINT=https://taphoagiamgia.com/wp-json/wp/v2/media
WP_USERS_ME_ENDPOINT=https://taphoagiamgia.com/wp-json/wp/v2/users/me
WP_AUTH_METHOD=application_password

# Publish defaults
WP_POST_STATUS=publish
WP_POST_TYPE=post
WP_CREATE_MISSING_TERMS=true
WP_DEFAULT_CATEGORY_SLUG=coupon
WP_FALLBACK_CATEGORY_SLUG=uncategorized
WP_DEFAULT_TAGS=tap-hoa-giam-gia,ma-giam-gia,san-deal,mua-sam-thong-minh
WP_FETCH_TIMEOUT_MS=20000
WP_FETCH_RETRIES=3
WP_FETCH_RETRY_DELAY_MS=2000

# Content rules
CONTENT_LANGUAGE=vi
CONTENT_MIN_WORDS=500
CONTENT_MAX_WORDS=1000
CONTENT_TIMEZONE=Asia/Ho_Chi_Minh
CONTENT_DISCLOSURE=Nội dung có thể chứa liên kết tiếp thị liên kết. Khi bạn mua hàng qua liên kết trên website, Tạp Hóa Giảm Giá có thể nhận hoa hồng nhỏ từ đối tác, nhưng giá mua của bạn không thay đổi.

# Internal links for CTA
WEBSITE_COUPON_URL=https://taphoagiamgia.com/coupon/
WEBSITE_DEAL_URL=https://taphoagiamgia.com/deal/
WEBSITE_BLOG_URL=https://taphoagiamgia.com/blogs/
WEBSITE_FACEBOOK_URL=https://www.facebook.com/profile.php?id=61588847056636

# Image upload defaults
WP_UPLOAD_FEATURED_IMAGE=true
WP_SET_FEATURED_IMAGE=true
IMAGE_MAIN_WIDTH=1200
IMAGE_MAIN_HEIGHT=630
IMAGE_THUMB_WIDTH=800
IMAGE_THUMB_HEIGHT=450
IMAGE_FORMAT=webp
IMAGE_ALT_PREFIX=Tạp Hóa Giảm Giá
